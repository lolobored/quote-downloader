#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="lolobored/quote-downloader"

# Auto-update: if gh is available, check for a newer jar and download it
if command -v gh &>/dev/null; then
  LATEST_TAG=$(gh release view --repo "$REPO" --json tagName -q .tagName 2>/dev/null || true)
  if [ -n "$LATEST_TAG" ] && [ ! -f "$SCRIPT_DIR/quote-downloader-${LATEST_TAG}.jar" ]; then
    echo "New version $LATEST_TAG available, updating..."
    gh release download "$LATEST_TAG" \
      --repo "$REPO" \
      --pattern "quote-downloader-*.jar" \
      --dir "$SCRIPT_DIR" \
      --clobber
    JARS=( $(ls "$SCRIPT_DIR"/quote-downloader-*.jar 2>/dev/null | sort -V) )
    COUNT=${#JARS[@]}
    if [ "$COUNT" -gt 1 ]; then
      for ((i=0; i<COUNT-1; i++)); do
        echo "Removed old jar: $(basename "${JARS[$i]}")"
        rm "${JARS[$i]}"
      done
    fi
    echo "Updated to $LATEST_TAG."
  fi
fi

JAR=$(ls "$SCRIPT_DIR"/quote-downloader-*.jar 2>/dev/null | sort -V | tail -1)
if [ -z "$JAR" ]; then
  echo "No quote-downloader jar found in $SCRIPT_DIR."
  echo "Install the GitHub CLI (gh) and re-run — the script will download the latest release automatically."
  exit 1
fi

JSON="$SCRIPT_DIR/quotes.json"
SESSION_FILE="$HOME/.bw_session"

# Use Java 25 via SDKMAN
export JAVA_HOME="$HOME/.sdkman/candidates/java/25-amzn"
export PATH="$JAVA_HOME/bin:$PATH"

# Load a previously stored Bitwarden session
if [ -f "$SESSION_FILE" ]; then
  export BW_SESSION=$(cat "$SESSION_FILE")
fi

BW_STATUS=$(bw status 2>/dev/null | grep -o '"status":"[^"]*"' | cut -d'"' -f4)

case "$BW_STATUS" in
  unauthenticated)
    echo "Not logged in to Bitwarden. Please run: bw login"
    exit 1
    ;;
  locked)
    echo "Unlocking Bitwarden vault..."
    export BW_SESSION=$(bw unlock --raw)
    echo "$BW_SESSION" > "$SESSION_FILE"
    chmod 600 "$SESSION_FILE"
    ;;
  unlocked)
    ;;
  *)
    echo "Could not determine Bitwarden status. Proceeding without unlock."
    ;;
esac

echo "Running $(basename "$JAR")..."
java -jar "$JAR" --json="$JSON" "$@"
